package service;

import model.Book;
import util.LibraryException;

import java.util.ArrayList;

public class LibraryService {

    private ArrayList<Book> books = new ArrayList<>();

    public void addBook(Book book) {
        books.add(book);
    }

    public ArrayList<Book> getBooks() {
        return books;
    }

    public void issueBook(int id) throws LibraryException {
        for (Book b : books) {
            if (b.getId() == id) {
                if (b.isIssued()) {
                    throw new LibraryException("Book already issued!");
                }
                b.setIssued(true);
                return;
            }
        }
        throw new LibraryException("Book not found!");
    }

    public void returnBook(int id) throws LibraryException {
        for (Book b : books) {
            if (b.getId() == id) {
                if (!b.isIssued()) {
                    throw new LibraryException("Book not issued!");
                }
                b.setIssued(false);
                return;
            }
        }
        throw new LibraryException("Book not found!");
    }

    public void removeBook(int id) throws LibraryException {
        for (Book b : books) {
            if (b.getId() == id) {
                books.remove(b);
                return;
            }
        }
        throw new LibraryException("Book not found!");
    }
}
